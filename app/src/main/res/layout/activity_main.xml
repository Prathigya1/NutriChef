<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Logo -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="140dp"
        android:layout_height="140dp"
        app:srcCompat="@drawable/logo"
        android:contentDescription="NutriChef Logo"
        android:scaleType="centerCrop"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="12dp"
        android:visibility="visible"
        android:adjustViewBounds="true" />

    <!-- Welcome message -->
    <TextView
        android:id="@+id/tvWelcome"
        android:text="Welcome to NutriChef! Find tasty recipes &amp; track nutrition."
        android:textSize="16sp"
        android:textColor="#666666"
        android:layout_marginBottom="14dp"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/textTitle"
        android:text="NutriChef"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:layout_marginBottom="6dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/textSubtitle"
        android:text="Search recipes • Ingredients • Nutrition"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="6dp">

        <Button
            android:id="@+id/btnSearchRecipe"
            android:text="Search Recipes"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginVertical="8dp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnPopularDishes"
            android:text="Popular Dishes"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginVertical="8dp"
            android:backgroundTint="#43A047"
            android:textColor="#FFFFFF"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnNutritionCalc"
            android:text="Nutrition Calculator"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginVertical="8dp"
            android:backgroundTint="#388E3C"
            android:textColor="#FFFFFF"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/tvFooter"
        android:text="Browse recipes, check ingredients and nutrition"
        android:textSize="12sp"
        android:textColor="#999999"
        android:layout_marginBottom="12dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</LinearLayout>

